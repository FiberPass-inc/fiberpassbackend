PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/fiberpass?replicaSet=rs0&directConnection=true
FRONTEND_ORIGIN=http://localhost:3000
FIBER_NETWORK=testnet
FIBER_PROVIDER=rpc
# Local Fiber node default. In production point this at the authenticated HTTPS gateway from docs/fiber-node-deployment.md.
FIBER_RPC_URL=http://127.0.0.1:8227
FIBER_RPC_TIMEOUT_MS=60000
FIBER_API_KEY=
# Local node peer id reported by node_info. Channel targets belong in FIBER_TARGET_PEER_IDS.
FIBER_PEER_ID=
FIBER_NODE_MIN_PEERS=1
FIBER_NODE_MIN_ACTIVE_CHANNELS=1
FIBER_NODE_MIN_OUTBOUND_LIQUIDITY_CKB=0.01
# Comma-separated external peer ids used when opening Fiber test channels.
FIBER_TARGET_PEER_IDS=
FIBER_TEST_CHANNEL_AMOUNT_CKB=0.01
FIBER_NODE_CKB_PRIVATE_KEY=
FIBER_EXIT_KEYSEND_TARGET_PUBKEY=
FIBER_EXIT_SETTLEMENT_PRIVATE_KEY=
FIBER_EXIT_SETTLEMENT_LOCK_HASH=
FIBER_EXIT_INVOICE_EXPIRY_SECONDS=86400
FIBERPASS_DAILY_SESSION_SPEND_LIMIT_CKB=100000
FIBERPASS_TREASURY_ADDRESS=
FIBERPASS_VAULT_CODE_HASH=
FIBERPASS_VAULT_HASH_TYPE=data2
FIBERPASS_VAULT_CELL_DEP_TX_HASH=
FIBERPASS_VAULT_CELL_DEP_INDEX=
FIBERPASS_VAULT_CELL_DEP_TYPE=code
FIBERPASS_OPERATOR_LOCK_HASH=
FIBERPASS_OPERATOR_PRIVATE_KEY=
CKB_TESTNET_RPC_URL=https://testnet.ckb.dev
CKB_TESTNET_INDEXER_URL=https://testnet.ckb.dev
JOYID_SERVER_URL=https://api.testnet.joyid.dev/api/v1
REQUEST_BODY_LIMIT=128kb
TRUST_PROXY=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=600
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_APP_CHARGE_MAX=120
# Use Mongo in every multi-instance environment. Mongo-store failures reject requests with 503.
RATE_LIMIT_STORE=mongo
# Short-lived credential used only in the SSE URL. Long-lived auth tokens remain in headers.
STREAM_TICKET_TTL_SECONDS=60
LOG_LEVEL=info

PAYMENT_WORKER_INTERVAL_MS=5000
PAYMENT_WORKER_BATCH_SIZE=10
RECONCILIATION_WORKER_INTERVAL_MS=15000
RECONCILIATION_WORKER_BATCH_SIZE=25
WEBHOOK_WORKER_INTERVAL_MS=5000
WEBHOOK_WORKER_BATCH_SIZE=10
WORKER_HEARTBEAT_STALE_MS=30000
WORKER_LEASE_TTL_MS=60000
WEBHOOK_DELIVERY_TIMEOUT_MS=5000
# 32 random bytes encoded as 64 hex characters or base64. Keep this stable and secret.
WEBHOOK_SECRET_ENCRYPTION_KEY=
# Separate 32-byte key used only for encrypted NWC connection secrets.
NWC_SECRET_ENCRYPTION_KEY=
NWC_REQUEST_TIMEOUT_MS=15000
# Development/regtest only. Production NWC relays must use wss://.
NWC_ALLOW_INSECURE_LOCAL_RELAY=false
# Separate 32-byte key used only for encrypted BTCPay API keys.
BTCPAY_SECRET_ENCRYPTION_KEY=
BTCPAY_REQUEST_TIMEOUT_MS=15000
# Development fixture only. Production BTCPay servers must use public HTTPS.
BTCPAY_ALLOW_INSECURE_LOCAL=false
# HTTPS resolver timeout for LNURL, Lightning Address, BOLT12 adapters, and recipient endpoints.
SCHEDULE_RESOLVER_TIMEOUT_MS=10000
# Local regtest fixture only. Production payment resolvers must use public HTTPS.
SCHEDULE_ALLOW_INSECURE_LOCAL_RESOLVERS=false
BITCOIN_NETWORK=regtest
BITCOIN_CORE_RPC_URL=
BITCOIN_CORE_RPC_USER=
BITCOIN_CORE_RPC_PASSWORD=
BITCOIN_CORE_RPC_TIMEOUT_MS=15000
CRON_SECRET=
AUTOMATION_MAX_INVOICE_CKB=1000
AUTOMATION_MAX_BATCH_CKB=5000
AUTOMATION_DAILY_LIMIT_CKB=10000

# Email notifications
PUBLIC_APP_URL=http://localhost:3000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=xbeach329@gmail.com
SMTP_PASS=
EMAIL_FROM_ADDRESS=xbeach329@gmail.com
EMAIL_FROM_NAME=FiberPass
NOTIFICATION_TOKEN_SECRET=
NOSTR_NOTIFICATION_SECRET_KEY=
NOSTR_NOTIFICATION_ALLOW_INSECURE_LOCAL_RELAY=false
NOTIFICATION_DELIVERY_RETENTION_DAYS=90
NOTIFICATION_DELIVERY_TIMEOUT_MS=15000
RECIPIENT_MAGIC_LINK_TTL_HOURS=72
